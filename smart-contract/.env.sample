# ── Casper Network ────────────────────────────────────────────────────────────
# RPC node for Testnet. Use node.testnet.cspr.cloud (free, no auth needed).
CASPER_NODE_ADDRESS=https://node.testnet.cspr.cloud

# Chain name: "casper-test" for Testnet, "casper" for Mainnet
CASPER_CHAIN_NAME=casper-test

# Path to your Ed25519 secret key PEM file.
# Generate keys: casper-client keygen ./keys
# Fund account:  https://testnet.cspr.live/tools/faucet
CASPER_SECRET_KEY_PATH=./keys/secret_key.pem

# Directory containing compiled Wasm files (output of cargo odra build)
WASM_DIR=./wasm

# Gas limits in motes (1 CSPR = 1,000,000,000 motes)
# 400 CSPR per contract deployment is conservative and safe
DEPLOY_GAS=400000000000
CALL_GAS=5000000000

# ── Contract hashes (fill in after deployment) ────────────────────────────────
# Copy from testnet.cspr.live after running deploy.sh
AGENT_REGISTRY_PACKAGE_HASH=
AGENT_REPUTATION_PACKAGE_HASH=
TASK_COORDINATOR_PACKAGE_HASH=

# ── Odra Livenet (used by cargo run --bin deploy --features=livenet) ──────────
ODRA_CASPER_LIVENET_SECRET_KEY_PATH=./keys/secret_key.pem
ODRA_CASPER_LIVENET_NODE_ADDRESS=https://node.testnet.cspr.cloud
ODRA_CASPER_LIVENET_EVENTS_URL=https://node.testnet.cspr.cloud/events
ODRA_CASPER_LIVENET_CHAIN_NAME=casper-test
