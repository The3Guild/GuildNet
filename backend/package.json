{
  "name": "guildnet-backend",
  "version": "1.0.0",
  "description": "GuildNet coordinator backend — orchestrates AI agents on Casper with x402 payments",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "start": "npm run build && node dist/server.js",
    "dev": "ts-node-dev --respawn src/server.ts",
    "lint": "eslint src/",
    "format": "prettier --write src/",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@casper-ecosystem/casper-eip-712": "1.2.1",
    "@make-software/casper-x402": "1.0.0",
    "@noble/hashes": "1.4.0",
    "@scure/bip32": "1.4.0",
    "@scure/bip39": "1.3.0",
    "axios": "1.7.2",
    "casper-js-sdk": "5.0.12",
    "cors": "2.8.5",
    "dotenv": "16.4.5",
    "express": "4.19.2",
    "express-rate-limit": "7.3.1",
    "viem": "2.17.0"
  },
  "devDependencies": {
    "@types/cors": "2.8.17",
    "@types/express": "4.17.21",
    "@types/node": "20.14.9",
    "@typescript-eslint/eslint-plugin": "^8.63.0",
    "@typescript-eslint/parser": "^8.63.0",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.9.4",
    "ts-node-dev": "2.0.0",
    "typescript": "5.5.3",
    "vitest": "^4.1.10"
  }
}
