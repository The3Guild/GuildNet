# ── Casper Network ─────────────────────────────────────────────────────────────
CASPER_NODE_RPC=https://node.testnet.casper.network/rpc
CASPER_CHAIN_NAME=casper-test

# ── Coordinator key (signs Casper transactions) ────────────────────────────────
# Path to secret_key.pem (Ed25519 or Secp256k1)
COORDINATOR_SECRET_KEY_PATH=./keys/secret_key.pem
# Algorithm: ed25519 | secp256k1
COORDINATOR_KEY_ALGO=ed25519

# ── Deployed Casper contract hashes (from smart-contract deploy) ───────────────
AGENT_REGISTRY_HASH=hash-d99fca67a1671de057392109594fab2bb2f412643f7f6aa22ca0f297c60c00c3
AGENT_REPUTATION_HASH=hash-87cb7a6c8e3a7a8fcc7aa1d4c0f8024859d54d300344ae8d53039b7f8ab11c69
TASK_COORDINATOR_HASH=hash-2216cbbc233837a526e1b3b47ec1e1535258151ef779a1bd8476266898105ac1

# ── CSPR.cloud (x402 Facilitator + REST API) ───────────────────────────────────
CSPR_CLOUD_AUTH_TOKEN=019f2c6f-4ebb-75da-8853-9b8bc029a465
CSPR_CLOUD_BASE_URL=https://api.cspr.cloud
X402_FACILITATOR_URL=https://x402-facilitator.cspr.cloud

# ── x402 payment config ────────────────────────────────────────────────────────
# CEP-18 Wrapped CSPR contract package hash on testnet (official from casper-x402 repo)
X402_ASSET_PACKAGE=3d80df21ba4ee4d66a2a1f60c32570dd5685e4b279f6538162a5fd1314847c1e
# Token metadata (used to build the EIP-712 domain)
X402_TOKEN_NAME=Wrapped CSPR
X402_TOKEN_VERSION=1
X402_TOKEN_DECIMALS=9
# Network identifier (CAIP-2 format)
X402_NETWORK=casper:casper-test
# Payment timeout in seconds
X402_TIMEOUT_SECONDS=300

# ── Venice AI ──────────────────────────────────────────────────────────────────
VENICE_API_KEY=VENICE_INFERENCE_KEY_nKyGntQKth88c07-8-K92JCQfq-0S3Unjj1cyjn1lj
VENICE_BASE_URL=https://api.venice.ai/api/v1

# ── Server ─────────────────────────────────────────────────────────────────────
PORT=3000
